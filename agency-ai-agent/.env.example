# ============================================
# AGENCY AI AGENT — ENVIRONMENT VARIABLES
# ============================================
# Copy this file, rename it to .env
# Fill in all your real API keys below
# NEVER share this file or commit it to GitHub
# ============================================

# --- CLAUDE AI (Get from: console.anthropic.com) ---
ANTHROPIC_API_KEY=your_claude_api_key_here

# --- SUPABASE DATABASE (Get from: supabase.com) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- GMAIL API (Get from: console.cloud.google.com) ---
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:3000/oauth2callback
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here

# --- YOUR AGENCY INFO ---
YOUR_NAME=Your Name
YOUR_EMAIL=youremail@gmail.com
YOUR_AGENCY_NAME=Your Agency Name
YOUR_PORTFOLIO_URL=https://yourportfolio.com
YOUR_PHONE=+91-XXXXXXXXXX
YOUR_CITY=Mumbai

# --- TELEGRAM BOT (Get from: @BotFather on Telegram) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- SERP API (Get from: serpapi.com — free 100 searches/month) ---
# Used by blogWriter.js to fetch real Google rankings for keyword analysis
# Leave empty to use LLM simulation fallback (still works without this)
SERPAPI_KEY=your_serpapi_key_here
