{
  "name": "agency-ai-agent",
  "version": "1.0.0",
  "description": "Your personal AI agent for your web design agency",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "health": "node final-health-check.js",
    "whatsapp": "node whatsapp-service.js",
    "autopilot": "node -e \"require('./system/autoPilot').startAutoPilot()\"",
